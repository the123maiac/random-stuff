# Copy to .env.local and fill in. Never commit .env.local.

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase ---
# Project Settings -> API in the Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Bypasses RLS. NEVER expose to the browser / NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=

# --- Provider key encryption (envelope encryption master key) ---
# 32 random bytes, base64-encoded. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
APP_ENCRYPTION_KEY=
# Optional key rotation: add APP_ENCRYPTION_KEY_2=<base64 32 bytes>, then set:
# APP_ENCRYPTION_KEY_ACTIVE=2
